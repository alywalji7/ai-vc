modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt", "libyaml"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Graph Ingest Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Scheduler Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Similarity API Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Radar Service"

[[workflows.workflow]]
name = "Frontend Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/frontend && npm install && npm run dev -- -p 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/backend && pip install -r requirements.txt && python main.py"
waitForPort = 8000

[[workflows.workflow]]
name = "Graph Ingest Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/graph_ingest && pip install -r requirements.txt && python main.py"
waitForPort = 8080

[[workflows.workflow]]
name = "Scheduler Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/scheduler && pip install -r requirements.txt && python main.py"
waitForPort = 8085

[[workflows.workflow]]
name = "Similarity API Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/similarity_api && pip install -r requirements.txt && python main.py"
waitForPort = 8090

[[workflows.workflow]]
name = "Radar Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/radar && pip install -r requirements.txt && python main.py"
waitForPort = 8095

[deployment]
run = ["sh", "-c", "cd services/frontend && npm install && npm run dev -- -p 5000"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5555
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8085
externalPort = 3002

[[ports]]
localPort = 8090
externalPort = 3003

[[ports]]
localPort = 8095
externalPort = 4200

[[ports]]
localPort = 9090
externalPort = 3000
