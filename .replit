modules = ["nodejs-20", "python-3.11", "postgresql-16", "python3"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales", "libxcrypt", "libyaml", "rdkafka", "wget", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Graph Ingest Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Scheduler Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Similarity API Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Radar Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IC Simulator Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Term Sheet Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telemetry Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Documentation Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Documentation Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Beta Feedback Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Billing Service"

[[workflows.workflow]]
name = "Frontend Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/frontend && npm install && npm run dev -- -p 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/backend && pip install -r requirements.txt && python main.py"
waitForPort = 8000

[[workflows.workflow]]
name = "Graph Ingest Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/graph_ingest && python main.py"
waitForPort = 8080

[[workflows.workflow]]
name = "Scheduler Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/scheduler && pip install -r requirements.txt && python main.py"
waitForPort = 8085

[[workflows.workflow]]
name = "Similarity API Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/similarity_api && pip install -r requirements.txt && python main.py"
waitForPort = 8090

[[workflows.workflow]]
name = "Radar Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/radar && pip install -r requirements.txt && python main.py"
waitForPort = 8095

[[workflows.workflow]]
name = "IC Simulator Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/ic_sim && pip install -r requirements.txt && PYTHONPATH=$PYTHONPATH:. python main.py"
waitForPort = 8060

[[workflows.workflow]]
name = "Term Sheet Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/term_sheet && pip install -r requirements.txt && python main.py"
waitForPort = 8070

[[workflows.workflow]]
name = "Telemetry Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/telemetry && pip install -r requirements.txt && python run.py"
waitForPort = 8100

[[workflows.workflow]]
name = "Documentation Dev Server"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx mdocs dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Documentation Server"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx markserv docs"
waitForPort = 8642

[[workflows.workflow]]
name = "Beta Feedback Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/beta_feedback && pip install -r requirements.txt && python main.py"
waitForPort = 8200

[[workflows.workflow]]
name = "Billing Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/billing && pip install -r requirements.txt && python main.py"
waitForPort = 8300

[deployment]
run = ["sh", "-c", "cd services/frontend && npm install && npm run dev -- -p 5000"]

