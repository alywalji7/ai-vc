modules = ["nodejs-20", "python-3.12"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Service"

[[workflows.workflow]]
name = "Frontend Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/frontend && npm install && npm run dev -- -p 5000"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "cd services/frontend && npm install && npm run dev -- -p 5000"]

[[ports]]
localPort = 5000
externalPort = 80
