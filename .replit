modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt", "libyaml"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Graph Ingest Service"

[[workflows.workflow]]
name = "Frontend Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/frontend && npm install && npm run dev -- -p 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/backend && pip install -r requirements.txt && python main.py"
waitForPort = 8000

[[workflows.workflow]]
name = "Graph Ingest Service"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd services/graph_ingest && pip install -r requirements.txt && python main.py"
waitForPort = 8080

[deployment]
run = ["sh", "-c", "cd services/frontend && npm install && npm run dev -- -p 5000"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080
