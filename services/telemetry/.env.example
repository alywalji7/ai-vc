# Database connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/aivc

# Service configuration
PORT=8100
HOST=0.0.0.0
BANKING_CSV_DIR=data/banking_csvs

# Stripe API keys for portfolio companies
